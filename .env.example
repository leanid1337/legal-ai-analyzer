# Скопируйте в .env и подставьте значения из Supabase Dashboard → Project Settings → API
#
# Важно: VITE_SUPABASE_ANON_KEY = только публичный ключ «anon» / «public» (часто JWT, начинается с eyJ).
# НЕ используйте секретный ключ (sb_secret_…) во фронтенде — будет ошибка в браузере.

VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# AI (Groq). Ключ: https://console.groq.com/keys — попадает в браузер; для продакшена лучше прокси на сервере.
# Достаточно одного из двух:
VITE_GROQ_API_KEY=gsk_your_groq_key_here
VITE_AI_API_KEY=
# По умолчанию: api.groq.com/openai/v1 + llama-3.3-70b-versatile
# VITE_AI_BASE_URL=https://api.groq.com/openai/v1
# VITE_AI_MODEL=llama-3.1-8b-instant
